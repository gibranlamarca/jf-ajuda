# Database — SQLite for local/MVP, replace with PostgreSQL URL for production
DATABASE_URL="file:./dev.db"
# For Postgres: DATABASE_URL="postgresql://user:password@localhost:5432/jfajuda?schema=public"

# App URL (used for generating links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Anti-abuse settings
CONFIRMATION_THRESHOLD=3
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_MS=600000

# Cron job secret (required for /api/cron/mark-stale — Vercel sets Authorization header automatically)
CRON_SECRET=your-cron-secret-here

# How many days without activity before a request becomes STALE (default: 7)
STALE_AFTER_DAYS=7
